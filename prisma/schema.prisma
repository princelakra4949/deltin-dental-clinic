// Prisma Schema — Deltin Dental Clinic
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  doctor    String
  service   String
  date      String
  time      String
  notes     String?
  status    AppointmentStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointments")
}

model Review {
  id        String   @id @default(cuid())
  name      String
  area      String?
  rating    Int      @default(5)
  text      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("reviews")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}
